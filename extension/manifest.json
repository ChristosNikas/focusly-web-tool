{
    "manifest_version":3,
    "name":"Focusly",
    "version":"1.0",
    "description":" Focusly is a productivity extension that helps you stay focused by blocking distracting websites ",
    "permissions": [
        "storage",
        "tabs",
        "webNavigation"   
    ],
    "host_permissions":[
        "<all_urls>"
    ],
    "action":{
        "default_popup":"popup.html",
        "default_icon":"Focusly.png"

    },
    "background":{
        "service_worker":"background.js"
    }
}